# ================================================================
# MLMonitor — Environment Configuration
# ================================================================
# Copy to .env and fill in values.
# ETL (VM) only needs the [ETL] section.
# Pipeline (Cloud) needs both sections.
# ================================================================

# --- ETL (VM) -------------------------------------------------
# Required for bootstrap and incremental ETL scripts.

# Database connection. SQLite for dev, PostgreSQL for prod.
DB_URL=sqlite:///mlmonitor_dev.db

# Artifacts output directory
ARTIFACTS_DIR=artifacts

# --- Pipeline (Cloud) -----------------------------------------
# Required for metrics calculation, PDF generation, S3 upload, email.
# Can be omitted on ETL-only VMs.

# AWS region (shared by Bedrock, S3, SES)
AWS_REGION=us-east-1

# Bedrock LLM for report narratives
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# S3 bucket for PDF upload (empty = upload disabled)
S3_BUCKET=
S3_PREFIX=mlmonitor/reports

# SES email (empty = email disabled; overridden by Secrets Manager in prod)
# SES_FROM_EMAIL=
# EMAIL_FROM=MLMonitor <noreply@mlmonitor.local>
# EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
